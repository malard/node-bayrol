# Connection details for running examples/ + integration tests against a
# live PoolManager. Copy to .env (gitignored) and fill in your own values.

# IPv4 / hostname of the PoolManager on your local network. The device
# uses a static IP — find it via the on-device help page (press Menu then
# Help) or your DHCP server's lease table.
BAYROL_HOST=192.168.1.100

# Modbus-TCP port. Always 502 unless your network has a NAT remap.
BAYROL_PORT=502

# Modbus unit ID. The PoolManager spec says "Device ID = Not Relevant
# (use e.g. 1)" — leave at 1 unless you have a Modbus gateway in front.
BAYROL_UNIT=1
